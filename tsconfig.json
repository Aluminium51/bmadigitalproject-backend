{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    
    // 🟢 เพิ่ม "DOM" เข้าไปในบรรทัดนี้ 
    "lib": ["ESNext", "DOM"], 
    
    "types": ["@types/bun"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}